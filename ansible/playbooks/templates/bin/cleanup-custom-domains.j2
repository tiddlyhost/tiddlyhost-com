#!/bin/bash
#
# Remove orphaned nginx configs for custom domains that no longer exist.
# Intended to be run periodically via cron on the host.
#

set -uo pipefail

COMPOSE="docker compose -f {{ home_dir }}/docker-compose.yml"
NGINX_DOMAINS="{{ nginx_domains_dir }}"

ACTIVE_DOMAINS=$($COMPOSE exec -T app bin/rails runner \
  "CustomDomain.fully_active.pluck(:domain).each { |d| puts d }")

REMOVED=0

for CONF in "$NGINX_DOMAINS"/*.conf; do
  [ -f "$CONF" ] || continue
  DOMAIN=$(basename "$CONF" .conf)

  if ! echo "$ACTIVE_DOMAINS" | grep -qx "$DOMAIN"; then
    echo "Removing orphaned config for $DOMAIN"
    rm "$CONF"
    REMOVED=$((REMOVED + 1))
  fi
done

if [ "$REMOVED" -gt 0 ]; then
  $COMPOSE exec -T web nginx -s reload
  echo "Nginx reloaded, removed $REMOVED orphaned config(s)"
fi

# Clean up letsencrypt cert files for domains that no longer have nginx configs.
# This catches certs that were issued but whose domain was later removed.
CERTBOT_LIVE="{{ certbot_dir_config }}/live"

for CERT_DIR in "$CERTBOT_LIVE"/*/; do
  [ -d "$CERT_DIR" ] || continue
  DOMAIN=$(basename "$CERT_DIR")

  # Skip the primary tiddlyhost cert
  [ "$DOMAIN" = "{{ primary_host }}" ] && continue

  if [ ! -f "$NGINX_DOMAINS/$DOMAIN.conf" ] && ! echo "$ACTIVE_DOMAINS" | grep -qx "$DOMAIN"; then
    echo "Deleting orphaned cert for $DOMAIN"
    certbot delete --cert-name "$DOMAIN" \
      --config-dir {{ certbot_dir_config }} \
      --work-dir {{ certbot_dir_work }} \
      --logs-dir {{ certbot_dir_logs }} \
      --non-interactive
  fi
done
